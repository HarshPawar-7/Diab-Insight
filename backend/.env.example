# DIABINSIGHT Backend Configuration

# Database
# For development: SQLite is auto-created
# For production: Use PostgreSQL connection string
DATABASE_URL=sqlite:///./app/data/diabinsight.db
# DATABASE_URL=postgresql://user:password@localhost:5432/diabinsight

# Security
SECRET_KEY=your-secret-key-change-in-production-8z6k9p2m1l

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Logging
LOG_LEVEL=INFO

# Model Paths
ML_ARTIFACTS_DIR=./ml/artifacts

# Environment
ENVIRONMENT=development
# ENVIRONMENT=production

# API Keys (if using external services)
# HUGGINGFACE_API_KEY=your-key-here
# SUPABASE_URL=your-url-here
# SUPABASE_API_KEY=your-key-here

# Feature Flags
ENABLE_DFU_DETECTION=true
ENABLE_CLINICAL_MODEL=false
ENABLE_IOT_INSOLE=false
